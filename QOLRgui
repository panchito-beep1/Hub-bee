    local searchBox = Instance.new("TextBox")
    searchBox.BackgroundColor3 = theme.FrameBg
    searchBox.Size = UDim2.new(1, -8, 0, 22)
    searchBox.Position = UDim2.new(0, 4, 0, 2)
    searchBox.Font = Enum.Font.RobotoMono
    searchBox.Text = ""
    searchBox.PlaceholderText = "Search..."
    searchBox.PlaceholderColor3 = theme.SubText
    searchBox.TextColor3 = theme.Text
    searchBox.TextSize = 12
    searchBox.Parent = listFrame
    applyCorner(searchBox, 2)
    applyBorder(searchBox, theme.Border)

    -- Scrolling area for options
    local scroll = Instance.new("ScrollingFrame")
    scroll.BackgroundTransparency = 1
    scroll.Size = UDim2.new(1, 0, 0, 0) -- will be set dynamically
    scroll.Position = UDim2.new(0, 0, 0, 30)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = theme.Accent
    scroll.Parent = listFrame

    local optionLayout = Instance.new("UIListLayout")
    optionLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optionLayout.Parent = scroll

    -- Create option buttons inside scroll
    local optionButtons = {}
    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.BackgroundTransparency = 1
        btn.Size = UDim2.new(1, -8, 0, 22)
        btn.Font = Enum.Font.RobotoMono
        btn.Text = " " .. tostring(opt)
        btn.TextColor3 = theme.TabNormalText
        btn.TextSize = 12
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.LayoutOrder = i
        btn.Parent = scroll

        local checkIndicator = Instance.new("TextLabel")
        checkIndicator.BackgroundTransparency = 1
        checkIndicator.AnchorPoint = Vector2.new(1, 0)
        checkIndicator.Position = UDim2.new(1, -6, 0, 3)
        checkIndicator.Size = UDim2.new(0, 16, 0, 16)
        checkIndicator.Font = Enum.Font.RobotoMono
        checkIndicator.Text = selected[opt] and "✓" or ""
        checkIndicator.TextColor3 = theme.Accent
        checkIndicator.TextSize = 12
        checkIndicator.Parent = btn

        btn.MouseEnter:Connect(function()
            if btn.Visible then btn.TextColor3 = theme.Accent end
        end)
        btn.MouseLeave:Connect(function()
            if btn.Visible then btn.TextColor3 = theme.TabNormalText end
        end)
        btn.MouseButton1Click:Connect(function()
            if selected[opt] then selected[opt] = nil else selected[opt] = true end
            checkIndicator.Text = selected[opt] and "✓" or ""
            updateHeader()
            if callback then
                local t = {}
                for k in pairs(selected) do table.insert(t, k) end
                callback(t)
            end
        end)
        optionButtons[opt] = {btn = btn, check = checkIndicator}
    end

    local function filterAndResize()
        local q = searchBox.Text:lower()
        local visibleCount = 0
        for _, opt in ipairs(options) do
            local btnData = optionButtons[opt]
            local match = (q == "" or opt:lower():find(q, 1, true))
            btnData.btn.Visible = match
            if match then visibleCount = visibleCount + 1 end
