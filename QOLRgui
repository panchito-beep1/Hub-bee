    container.Size = UDim2.new(1, 0, 0, 24)
    container.LayoutOrder = self:_nextOrder()
    container.ClipsDescendants = true
    container.Parent = self._page

    local header = Instance.new("TextButton")
    header.BackgroundColor3 = theme.FrameBg
    header.Size = UDim2.new(1, 0, 0, 24)
    header.Font = Enum.Font.RobotoMono
    header.Text = string.format(" %s: %s", text, tostring(selected))
    header.TextColor3 = theme.Text
    header.TextSize = 13
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.Parent = container
    applyCorner(header, 2)
    applyBorder(header, theme.Border)

    local listFrame = Instance.new("Frame")
    listFrame.BackgroundColor3 = theme.TabNormal
    listFrame.Position = UDim2.new(0, 0, 0, 26)
    listFrame.Size = UDim2.new(1, 0, 0, 0)
    listFrame.ClipsDescendants = true
    listFrame.Parent = container
    applyBorder(listFrame, theme.Border)

    -- Search box inside the list
    local searchBox = Instance.new("TextBox")
    searchBox.BackgroundColor3 = theme.FrameBg
    searchBox.Size = UDim2.new(1, -8, 0, 22)
    searchBox.Position = UDim2.new(0, 4, 0, 2)
    searchBox.Font = Enum.Font.RobotoMono
    searchBox.Text = ""
    searchBox.PlaceholderText = "Search..."
    searchBox.PlaceholderColor3 = theme.SubText
    searchBox.TextColor3 = theme.Text
    searchBox.TextSize = 12
    searchBox.Parent = listFrame
    applyCorner(searchBox, 2)
    applyBorder(searchBox, theme.Border)

    local optionList = Instance.new("Frame")
    optionList.BackgroundTransparency = 1
    optionList.Size = UDim2.new(1, 0, 0, 0)
    optionList.Position = UDim2.new(0, 0, 0, 28)
    optionList.Parent = listFrame

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = optionList

    -- Create all option buttons once
    local optionButtons = {}
    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.BackgroundTransparency = 1
        btn.Size = UDim2.new(1, 0, 0, 22)
        btn.Font = Enum.Font.RobotoMono
        btn.Text = " " .. tostring(opt)
        btn.TextColor3 = theme.TabNormalText
        btn.TextSize = 12
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.LayoutOrder = i
        btn.Parent = optionList

        btn.MouseEnter:Connect(function() btn.TextColor3 = theme.Accent end)
        btn.MouseLeave:Connect(function() btn.TextColor3 = theme.TabNormalText end)

        btn.MouseButton1Click:Connect(function()
            selected = opt
            header.Text = string.format(" %s: %s", text, tostring(selected))
            isOpen = false
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 24)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 0)}):Play()
            if callback then callback(selected) end
        end)
        table.insert(optionButtons, btn)
    end

    -- Filter function
    local function filterOptions()
        local q = searchBox.Text:lower()
        local visibleCount = 0
        for _, btn in ipairs(optionButtons) do
            local match = (q == "" or btn.Text:lower():find(q, 1, true))
            btn.Visible = match
            if match then visibleCount = visibleCount + 1 end
        end
        -- Resize optionList height
        optionList.Size = UDim2.new(1, 0, 0, visibleCount * 22)
        -- Adjust total listFrame height
        local totalHeight = 28 + visibleCount * 22
        if isOpen then
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 26 + totalHeight)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, totalHeight)}):Play()
        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(filterOptions)

    header.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            filterOptions() -- recalc size for current filter
        else
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 24)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 0)}):Play()
        end
    end)
end

-- ── NEW: Multi‑Select Dropdown ────────────────────────────────────────────────
function TabComponent:AddMultiSelectDropdown(text, options, defaults, callback)
    local theme = getTheme(self)
    -- defaults is a table of values, e.g. {"Easy", "Hard"}
    local selected = {}
    if defaults then
        for _, v in ipairs(defaults) do
            selected[v] = true
        end
    end
    local isOpen = false

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 24)
    container.LayoutOrder = self:_nextOrder()
    container.ClipsDescendants = true
    container.Parent = self._page

    local function updateHeader()
        local count = 0
        for _ in pairs(selected) do count = count + 1 end
        if count == 0 then
            header.Text = string.format(" %s: None", text)
        elseif count == #options then
            header.Text = string.format(" %s: All", text)
        else
            header.Text = string.format(" %s: %d selected", text, count)
        end
    end

    local header = Instance.new("TextButton")
    header.BackgroundColor3 = theme.FrameBg
    header.Size = UDim2.new(1, 0, 0, 24)
    header.Font = Enum.Font.RobotoMono
    header.TextColor3 = theme.Text
    header.TextSize = 13
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.Parent = container
    applyCorner(header, 2)
    applyBorder(header, theme.Border)

    updateHeader()

    local listFrame = Instance.new("Frame")
    listFrame.BackgroundColor3 = theme.TabNormal
    listFrame.Position = UDim2.new(0, 0, 0, 26)
    listFrame.Size = UDim2.new(1, 0, 0, 0)
    listFrame.ClipsDescendants = true
    listFrame.Parent = container
    applyBorder(listFrame, theme.Border)

    -- ScrollingFrame inside listFrame to handle many options
    local scroll = Instance.new("ScrollingFrame")
    scroll.BackgroundTransparency = 1
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = theme.Accent
    scroll.Parent = listFrame

    local optionLayout = Instance.new("UIListLayout")
    optionLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optionLayout.Parent = scroll

    -- "Select All" / "Deselect All" buttons
    local selectAllBtn = Instance.new("TextButton")
    selectAllBtn.BackgroundColor3 = theme.FrameBg
    selectAllBtn.Size = UDim2.new(1, -8, 0, 20)
    selectAllBtn.Position = UDim2.new(0, 4, 0, 2)
    selectAllBtn.Font = Enum.Font.RobotoMono
    selectAllBtn.Text = "Select All"
    selectAllBtn.TextColor3 = theme.Accent
    selectAllBtn.TextSize = 12
    selectAllBtn.Parent = listFrame
    applyCorner(selectAllBtn, 2)
    applyBorder(selectAllBtn, theme.Border)

    local deselectAllBtn = Instance.new("TextButton")
    deselectAllBtn.BackgroundColor3 = theme.FrameBg
    deselectAllBtn.Size = UDim2.new(1, -8, 0, 20)
    deselectAllBtn.Position = UDim2.new(0, 4, 0, 24)
    deselectAllBtn.Font = Enum.Font.RobotoMono
    deselectAllBtn.Text = "Deselect All"
    deselectAllBtn.TextColor3 = theme.Accent
    deselectAllBtn.TextSize = 12
    deselectAllBtn.Parent = listFrame
    applyCorner(deselectAllBtn, 2)
    applyBorder(deselectAllBtn, theme.Border)

    -- Option buttons (placed inside scroll, start after the two buttons)
    local optionStartY = 48
    local optionHeight = 22
    local optionButtons = {}
    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.BackgroundTransparency = 1
        btn.Size = UDim2.new(1, -8, 0, optionHeight)
        btn.Position = UDim2.new(0, 4, 0, optionStartY + (i-1)*optionHeight)
        btn.Font = Enum.Font.RobotoMono
        btn.Text = " " .. tostring(opt)
        btn.TextColor3 = theme.TabNormalText
        btn.TextSize = 12
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Parent = scroll

        local checkIndicator = Instance.new("TextLabel")
        checkIndicator.BackgroundTransparency = 1
        checkIndicator.AnchorPoint = Vector2.new(1, 0)
        checkIndicator.Position = UDim2.new(1, -6, 0, 3)
        checkIndicator.Size = UDim2.new(0, 16, 0, 16)
        checkIndicator.Font = Enum.Font.RobotoMono
        checkIndicator.Text = selected[opt] and "✓" or ""
        checkIndicator.TextColor3 = theme.Accent
        checkIndicator.TextSize = 12
        checkIndicator.Parent = btn

        btn.MouseEnter:Connect(function() btn.TextColor3 = theme.Accent end)
        btn.MouseLeave:Connect(function() btn.TextColor3 = theme.TabNormalText end)

        btn.MouseButton1Click:Connect(function()
            if selected[opt] then
                selected[opt] = nil
            else
                selected[opt] = true
            end
            checkIndicator.Text = selected[opt] and "✓" or ""
            updateHeader()
            if callback then
                local t = {}
                for k in pairs(selected) do table.insert(t, k) end
                callback(t)
            end
        end)
        optionButtons[opt] = {btn = btn, check = checkIndicator}
    end

    -- Update scroll canvas size
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * optionHeight)

    local function openClose()
        isOpen = not isOpen
        if isOpen then
            -- Height: header + 48 (buttons) + #options*optionHeight
            local totalHeight = 48 + #options * optionHeight
            -- Constrain to max 180px
            local displayedHeight = math.min(totalHeight, 180)
            scroll.Size = UDim2.new(1, 0, 0, displayedHeight)
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 26 + 2 + displayedHeight)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 2 + displayedHeight)}):Play()
        else
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 24)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 0)}):Play()
        end
    end

    header.MouseButton1Click:Connect(openClose)
    selectAllBtn.MouseButton1Click:Connect(function()
        for _, opt in ipairs(options) do
            selected[opt] = true
            if optionButtons[opt] then
                optionButtons[opt].check.Text = "✓"
            end
        end
        updateHeader()
        if callback then callback(options) end
    end)
    deselectAllBtn.MouseButton1Click:Connect(function()
        for k in pairs(selected) do selected[k] = nil end
        for _, opt in ipairs(options) do
            if optionButtons[opt] then
                optionButtons[opt].check.Text = ""
            end
        end
        updateHeader()
        if callback then callback({}) end
    end)
end

