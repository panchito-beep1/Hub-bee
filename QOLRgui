        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(filterAndResize)

    header.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            filterAndResize()
        else
            TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 24)}):Play()
            TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 0)}):Play()
        end
    end)
end

-- ── Tab:AddLabel(text, color) ─────────────────────────────────────────────────
function TabComponent:AddLabel(text, color)
    local theme = getTheme(self)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 0)
    lbl.LayoutOrder = self:_nextOrder()
    lbl.Font = Enum.Font.RobotoMono
    lbl.Text = text
    lbl.TextColor3 = color or theme.Text
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextWrapped = true
    lbl.RichText = true
    lbl.Parent = self._page

    lbl:GetPropertyChangedSignal("TextBounds"):Connect(function()
        lbl.Size = UDim2.new(1, 0, 0, lbl.TextBounds.Y + 2)
    end)
    return lbl
end

-- ── Tab:AddSection(text) ─────────────────────────────────────────────────────
function TabComponent:AddSection(text)
    local theme = getTheme(self)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.LayoutOrder = self:_nextOrder()
