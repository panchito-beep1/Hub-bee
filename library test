local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- ||          R-GUI LIBRARY CORE          ||
-- ==========================================
local RGui = {}

-- Theme Colors
local Theme = {
	MainBlue = Color3.fromRGB(41, 74, 122),
	Background = Color3.fromRGB(21, 22, 23),
	TextColor = Color3.fromRGB(255, 255, 255),
	Font = Enum.Font.Code -- Changed to Code for a cleaner, modern look
}

function RGui:CreateWindow(titleText)
	local WindowData = {}
	
	-- Main ScreenGui
	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "RGui_Library"
	ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	-- Header/Drag Frame
	local HeaderFrame = Instance.new("Frame")
	HeaderFrame.Name = "Header"
	HeaderFrame.Size = UDim2.new(0, 250, 0, 30)
	HeaderFrame.Position = UDim2.new(0.5, -125, 0.3, 0)
	HeaderFrame.BackgroundColor3 = Theme.MainBlue
	HeaderFrame.BorderSizePixel = 0
	HeaderFrame.Parent = ScreenGui
	
	local HeaderCorner = Instance.new("UICorner")
	HeaderCorner.CornerRadius = UDim.new(0, 4)
	HeaderCorner.Parent = HeaderFrame
	
	-- Square off the bottom of the header
	local HeaderHider = Instance.new("Frame")
	HeaderHider.Size = UDim2.new(1, 0, 0, 4)
	HeaderHider.Position = UDim2.new(0, 0, 1, -4)
	HeaderHider.BackgroundColor3 = Theme.MainBlue
	HeaderHider.BorderSizePixel = 0
	HeaderHider.Parent = HeaderFrame

	-- Title
	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1, -30, 1, 0)
	Title.Position = UDim2.new(0, 10, 0, 0)
	Title.BackgroundTransparency = 1
	Title.Text = titleText or "R-gui example"
	Title.TextColor3 = Theme.TextColor
	Title.TextXAlignment = Enum.TextXAlignment.Left
	Title.Font = Theme.Font
	Title.TextSize = 16
	Title.Parent = HeaderFrame
	
	-- Close Button (Visual only for now, based on your image)
	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Size = UDim2.new(0, 20, 0, 20)
	CloseBtn.Position = UDim2.new(1, -25, 0.5, -10)
	CloseBtn.BackgroundTransparency = 1
	CloseBtn.Text = "X"
	CloseBtn.TextColor3 = Theme.TextColor
	CloseBtn.Font = Enum.Font.GothamBold
	CloseBtn.TextSize = 14
	CloseBtn.Parent = HeaderFrame
	
	CloseBtn.MouseButton1Click:Connect(function()
		ScreenGui:Destroy()
	end)

	-- Main Body Frame
	local BodyFrame = Instance.new("Frame")
	BodyFrame.Name = "Body"
	BodyFrame.Size = UDim2.new(1, 0, 0, 250)
	BodyFrame.Position = UDim2.new(0, 0, 1, 0)
	BodyFrame.BackgroundColor3 = Theme.Background
	BodyFrame.BorderSizePixel = 0
	BodyFrame.Parent = HeaderFrame
	
	local BodyCorner = Instance.new("UICorner")
	BodyCorner.CornerRadius = UDim.new(0, 4)
	BodyCorner.Parent = BodyFrame
	
	-- Resize icon at bottom right
	local ResizeIcon = Instance.new("ImageLabel")
	ResizeIcon.Size = UDim2.new(0, 15, 0, 15)
	ResizeIcon.Position = UDim2.new(1, -15, 1, -15)
	ResizeIcon.BackgroundTransparency = 1
	ResizeIcon.Image = "rbxassetid://10709769598" -- Your corner icon
	ResizeIcon.ImageColor3 = Theme.MainBlue
	ResizeIcon.Parent = BodyFrame

	-- Container for elements (Uses UIListLayout for automatic stacking)
	local Container = Instance.new("Frame")
	Container.Name = "Container"
	Container.Size = UDim2.new(1, -20, 1, -20)
	Container.Position = UDim2.new(0, 10, 0, 10)
	Container.BackgroundTransparency = 1
	Container.Parent = BodyFrame

	local UIListLayout = Instance.new("UIListLayout")
	UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	UIListLayout.Padding = UDim.new(0, 15)
	UIListLayout.Parent = Container
	
	-- Simple Window Dragging Logic
	local dragging, dragInput, dragStart, startPos
	HeaderFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = HeaderFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	HeaderFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			HeaderFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	-- ==========================================
	-- ||         COMPONENT FUNCTIONS          ||
	-- ==========================================
	
	function WindowData:CreateButton(buttonText, labelText, callback)
		local Element = Instance.new("Frame")
		Element.Size = UDim2.new(1, 0, 0, 25)
		Element.BackgroundTransparency = 1
		Element.Parent = Container
		
		local Btn = Instance.new("TextButton")
		Btn.Size = UDim2.new(0, 80, 1, 0)
		Btn.BackgroundColor3 = Theme.MainBlue
		Btn.Text = buttonText
		Btn.TextColor3 = Theme.TextColor
		Btn.Font = Theme.Font
		Btn.TextSize = 14
		Btn.BorderSizePixel = 1
		Btn.BorderColor3 = Color3.fromRGB(0,0,0)
		Btn.Parent = Element
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, -90, 1, 0)
		Label.Position = UDim2.new(0, 90, 0, 0)
		Label.BackgroundTransparency = 1
		Label.Text = labelText
		Label.TextColor3 = Theme.TextColor
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Font = Theme.Font
		Label.TextSize = 14
		Label.Parent = Element
		
		Btn.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)
	end
	
	function WindowData:CreateCheckbox(labelText, defaultState, callback)
		local toggled = defaultState or false
		
		local Element = Instance.new("Frame")
		Element.Size = UDim2.new(1, 0, 0, 25)
		Element.BackgroundTransparency = 1
		Element.Parent = Container
		
		local Box = Instance.new("TextButton")
		Box.Size = UDim2.new(0, 25, 0, 25)
		Box.BackgroundColor3 = Theme.Background
		Box.BorderColor3 = Color3.fromRGB(80, 80, 80) -- Subtle border
		Box.BorderSizePixel = 1
		Box.Text = toggled and "✓" or ""
		Box.TextColor3 = Theme.TextColor
		Box.TextSize = 18
		Box.Parent = Element
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, -35, 1, 0)
		Label.Position = UDim2.new(0, 35, 0, 0)
		Label.BackgroundTransparency = 1
		Label.Text = labelText
		Label.TextColor3 = Theme.TextColor
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Font = Theme.Font
		Label.TextSize = 14
		Label.Parent = Element
		
		Box.MouseButton1Click:Connect(function()
			toggled = not toggled
			Box.Text = toggled and "✓" or ""
			if callback then callback(toggled) end
		end)
	end

	function WindowData:CreateSlider(labelText, callback)
		local Element = Instance.new("Frame")
		Element.Size = UDim2.new(1, 0, 0, 45)
		Element.BackgroundTransparency = 1
		Element.Parent = Container
		
		-- Background Line
		local Line = Instance.new("Frame")
		Line.Size = UDim2.new(1, -10, 0, 4)
		Line.Position = UDim2.new(0, 5, 0, 10)
		Line.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		Line.BorderSizePixel = 0
		Line.Parent = Element
		
		-- Dragger Nub
		local Nub = Instance.new("TextButton")
		Nub.Size = UDim2.new(0, 10, 0, 20)
		Nub.Position = UDim2.new(0.1, -5, 0.5, -10)
		Nub.BackgroundColor3 = Theme.MainBlue
		Nub.BorderSizePixel = 0
		Nub.Text = ""
		Nub.Parent = Line
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, 0, 0, 20)
		Label.Position = UDim2.new(0, 0, 0, 25)
		Label.BackgroundTransparency = 1
		Label.Text = labelText
		Label.TextColor3 = Theme.TextColor
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Font = Theme.Font
		Label.TextSize = 14
		Label.Parent = Element
		
		-- Basic Slider Math & Logic
		local draggingSlider = false
		Nub.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = true end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
				local mousePos = UserInputService:GetMouseLocation().X
				local linePos = Line.AbsolutePosition.X
				local lineSize = Line.AbsoluteSize.X
				local relativePos = math.clamp((mousePos - linePos) / lineSize, 0, 1)
				
				Nub.Position = UDim2.new(relativePos, -5, 0.5, -10)
				
				if callback then callback(relativePos) end
			end
		end)
	end
	
	function WindowData:CreateLabel(labelText, isColored)
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, 0, 0, 20)
		Label.BackgroundTransparency = 1
		Label.Text = labelText
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Font = Theme.Font
		Label.TextSize = 14
		Label.Parent = Container
		
		if isColored then
			Label.TextColor3 = Color3.fromRGB(255, 0, 4) -- The Red from your image
		else
			Label.TextColor3 = Theme.TextColor
		end
	end

	return WindowData
end
