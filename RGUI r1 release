    R-GUI Library v1.1
    A clean Roblox GUI library with reusable components.

    Components:
        Window:AddTab(name)
        Tab:AddButton(text, callback)
        Tab:AddCheckbox(text, default, callback)
        Tab:AddSlider(text, min, max, default, callback)
        Tab:AddDropdown(text, options, default, callback)
        Tab:AddColorPicker(text, defaultColor, callback)
        Tab:AddLabel(text, color)
        Tab:AddSection(text)
        Tab:AddSeparator()

    Usage:
        local RGui = require(path.to.RGui)
        local win  = RGui.new("My Window")
        
        local mainTab = win:AddTab("Main")
        mainTab:AddButton("Click me!", function() print("clicked") end)
        
        local settingsTab = win:AddTab("Settings")
        settingsTab:AddDropdown("Select Mode", {"Easy", "Hard"}, "Easy", function(v) print(v) end)
        settingsTab:AddColorPicker("Accent Color", Color3.new(1,0,0), function(c) print(c) end)
]]

